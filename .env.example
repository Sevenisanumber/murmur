# Alpaca API (get from alpaca.markets — free paper trading account)
# Used for historical daily price data (OHLCV) and paper trading
ALPACA_API_KEY=your_api_key_here
ALPACA_SECRET_KEY=your_secret_key_here
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# Anthropic API (get from console.anthropic.com)
# Used by scripts/weekly_digest.py for AI analysis
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Pushover notifications (get from pushover.net)
# Used by paper_trader.py (buy/sell alerts) and check_positions.py (daily summary)
PUSHOVER_USER_KEY=your_pushover_user_key_here
PUSHOVER_API_TOKEN=your_pushover_app_token_here
